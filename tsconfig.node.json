{
  "compilerOptions": {
    "composite": true,           // 启用组合编译模式，用于项目引用
    "skipLibCheck": true,        // 跳过声明文件的类型检查，加速编译
    "module": "ESNext",          // 使用 ESNext 模块系统
    "moduleResolution": "bundler", // 使用 bundler 解析策略（Vite 5+ 推荐）
    "allowSyntheticDefaultImports": true, // 允许从没有默认导出的模块进行默认导入
    "strict": true               // 启用所有严格类型检查选项
  },
  "include": ["vite.config.ts"]  // 仅包含 Vite 配置文件
}
